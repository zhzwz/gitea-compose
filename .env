# @see https://docs.gitea.com/zh-cn/installation/install-with-docker#环境变量
#
# 以下环境变量，只有 `GITEA_` 开头的变量才会在每次容器启动时使用并覆盖 custom/conf/app.ini 中的配置
# 其他变量仅在首次启动时使用，之后不会再生效

APP_NAME=GitServer
# 禁用 SSH
DISABLE_SSH=true
# 禁用注册
DISABLE_REGISTRATION=true

# 数据库类型 [sqlite3, mysql, postgres]
DB_TYPE=sqlite3

# 容器内运行 Gitea 的用户的 UID/GID
USER_UID=1000
USER_GID=1000

# 资源限制
LIMITS_CPUS=1.0
LIMITS_MEMORY=1024M

# 外部访问地址
GITEA_ROOT_URL=https://gitea.zhzwz.com

# 界面默认主题
GITEA_THEME=gitea
# 语言
GITEA_I18N_LANGS=zh-CN
GITEA_I18N_NAMES=简体中文
# 时间格式
GITEA_TIME_FORMAT=RFC1123
# 时间区域
GITEA_TIME_LOCATION=Asia/Shanghai
# 启用内置 git-lfs
GITEA_ENABLE_LFS=true

# 启用 OpenID 登录
GITEA_ENABLE_OPENID_SIGNIN=false
# 启用 OpenID 注册
GITEA_ENABLE_OPENID_SIGNUP=false
# 启用 Sitemap
GITEA_ENABLE_SITEMAP=true
# 启用 Feed
GITEA_ENABLE_FEED=true
